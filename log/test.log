INSERT INTO "posts" ("id", "title", "body", "created_at", "updated_at", "creator_id", "category_id") VALUES (647284951, 'Quasi pariatur voluptates ipsam officia.', 'In aspernatur corrupti. Esse nesciunt sed. Reprehenderit odio consectetur. Illo minima deserunt. Dolorem quia quam. Ut totam amet. Aperiam maiores quidem. Temporibus sit non. Maiores non repudiandae. Labore ex.', '2025-04-01 11:22:18.696057', '2025-04-01 11:22:18.696057', 980190962, 980190962);
